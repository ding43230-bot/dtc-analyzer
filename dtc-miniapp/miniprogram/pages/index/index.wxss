/* 首页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-decoration::after {
  content: '';
  position: absolute;
  bottom: -300rpx;
  left: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

/* 头部 */
.header {
  padding: 80rpx 0 40rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.logo-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 64rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 输入卡片 */
.input-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.url-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #999;
}

.analyze-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  letter-spacing: 4rpx;
}

.analyze-btn::after {
  border: none;
}

/* 示例网站 */
.examples {
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.examples-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

.examples-list {
  display: flex;
  gap: 16rpx;
}

.example-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  backdrop-filter: blur(10px);
}

.example-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.example-name {
  font-size: 22rpx;
  color: #fff;
}

/* 分析进度 */
.progress-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.progress-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.progress-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

.step.active .step-dot {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.step-text {
  font-size: 22rpx;
  color: #999;
}

.step.active .step-text {
  color: #333;
  font-weight: 500;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 12rpx;
  margin-bottom: 36rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.progress-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 功能介绍 */
.features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.feature-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  backdrop-filter: blur(10px);
}

.feature-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

/* 错误提示 */
.error-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  z-index: 999;
}

.error-text {
  font-size: 28rpx;
  color: #fff;
}

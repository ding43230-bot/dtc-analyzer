/* 报告页样式 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.loading-animation {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 40rpx;
}

.pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

.loading-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
}

.loading-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.loading-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 报告内容 */
.report-content {
  padding-bottom: 200rpx;
}

/* 头部 */
.report-header {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.header-content {
  position: relative;
  text-align: center;
}

.report-label {
  display: inline-block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.overall-score-wrapper {
  margin-bottom: 24rpx;
}

.score-ring {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  position: relative;
}

.score-ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid rgba(255, 255, 255, 0.2);
}

.score-ring-fill {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid transparent;
  border-top-color: #fff;
  border-right-color: #fff;
  transform: rotate(-45deg);
}

.score-ring-fill.good {
  border-top-color: #34d399;
  border-right-color: #34d399;
}

.score-ring-fill.medium {
  border-top-color: #fbbf24;
  border-right-color: #fbbf24;
}

.score-ring-fill.bad {
  border-top-color: #f87171;
  border-right-color: #f87171;
}

.score-ring-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.score-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-url {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  word-break: break-all;
  margin-bottom: 16rpx;
}

.score-level {
  display: inline-block;
  padding: 8rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.score-level.good {
  background: rgba(52, 211, 153, 0.3);
  color: #34d399;
}

.score-level.medium {
  background: rgba(251, 191, 36, 0.3);
  color: #fbbf24;
}

.score-level.bad {
  background: rgba(248, 113, 113, 0.3);
  color: #f87171;
}

/* 四维分数 */
.dimension-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: -40rpx 32rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.dimension-grid {
  display: flex;
  justify-content: space-between;
}

.dimension-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dimension-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.dimension-circle.good {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.dimension-circle.medium {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.dimension-circle.bad {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
}

.dimension-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.dimension-label {
  font-size: 24rpx;
  color: #666;
}

/* 分析页面来源 */
.pages-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.pages-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.page-tag {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.page-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.page-name {
  font-size: 22rpx;
  color: #374151;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分析板块 */
.analysis-sections {
  padding: 0 32rpx;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.section-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.section-icon-wrapper.uiux {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.section-icon-wrapper.seo {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}

.section-icon-wrapper.ads {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.section-icon-wrapper.email {
  background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
}

.section-icon {
  font-size: 36rpx;
}

.section-info {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-subtitle {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.section-score-wrapper {
  margin-right: 16rpx;
}

.section-score {
  font-size: 40rpx;
  font-weight: 700;
}

.section-score.good {
  color: #10b981;
}

.section-score.medium {
  color: #f59e0b;
}

.section-score.bad {
  color: #ef4444;
}

.section-arrow {
  font-size: 24rpx;
  color: #9ca3af;
  transition: transform 0.3s ease;
}

.section-arrow.expanded {
  transform: rotate(180deg);
}

.section-content {
  padding: 0 24rpx 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.check-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f9fafb;
}

.check-item:last-child {
  border-bottom: none;
}

.check-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.check-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

.check-score-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.check-score-badge.good {
  background: #d1fae5;
  color: #059669;
}

.check-score-badge.medium {
  background: #fef3c7;
  color: #d97706;
}

.check-score-badge.bad {
  background: #fee2e2;
  color: #dc2626;
}

.check-feedback {
  display: block;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.check-evidence {
  display: flex;
  align-items: flex-start;
  background: #f9fafb;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.evidence-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  margin-top: 4rpx;
}

.evidence-text {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.check-suggestion {
  display: block;
  font-size: 26rpx;
  color: #7c3aed;
  line-height: 1.6;
  padding: 16rpx;
  background: #f5f3ff;
  border-radius: 12rpx;
}

.issues {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.issues-title {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.issue-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.issue-dot {
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
}

.issue-text {
  flex: 1;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.btn-share::after {
  border: none;
}

.btn-primary {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 错误页面 */
.error-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 60rpx;
}

.error-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fee2e2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.error-icon {
  font-size: 60rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 48rpx;
}

.error-page .btn-primary {
  width: 100%;
}

/* 总结文本 */
.summary-text {
  padding: 20rpx 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.summary-text text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 无数据提示 */
.no-data {
  padding: 40rpx 0;
  text-align: center;
}

.no-data text {
  font-size: 26rpx;
  color: #9ca3af;
}
